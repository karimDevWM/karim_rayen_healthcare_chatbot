# Healthcare Chatbot - Environment Configuration
# Copy this file to .env and customize the values as needed

# Application Environment
ENVIRONMENT=development
# Options: development, production

# Backend API Configuration
BACKEND_URL=http://127.0.0.1:5000
# The backend API endpoint for chatbot responses

# UI Customization
PRIMARY_COLOR=#1E88E5
SECONDARY_COLOR=#FFC107

# File Upload Settings
MAX_FILE_SIZE_MB=10
# Maximum file size for uploads in MB

# Feature Flags
ENABLE_VOICE_INPUT=true
ENABLE_CONVERSATION_EXPORT=true

# API Keys (Optional - for advanced features)
# Uncomment and configure as needed

# OpenAI API (for advanced AI features)
# OPENAI_API_KEY=your-openai-api-key-here

# Google Cloud API (for speech-to-text and vision)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
# GOOGLE_SPEECH_API_KEY=your-google-speech-api-key
# GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Azure Cognitive Services (for speech and vision)
# AZURE_SPEECH_KEY=your-azure-speech-key
# AZURE_SPEECH_REGION=your-azure-region
# AZURE_CV_KEY=your-azure-computer-vision-key
# AZURE_CV_ENDPOINT=your-azure-cv-endpoint

# AWS Services (for transcribe and other services)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# Security Settings
ENCRYPT_UPLOADS=true
AUTO_DELETE_UPLOADS=true
UPLOAD_RETENTION_HOURS=24

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=10
STREAMLIT_THEME_BASE=light